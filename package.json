{
  "name": "signwell-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for SignWell workflows.",
  "type": "module",
  "main": "build/index.js",
  "private": false,
  "license": "MIT",
  "author": "Bidsketch, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bidsketch/signwell-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Bidsketch/signwell-mcp/issues"
  },
  "homepage": "https://github.com/Bidsketch/signwell-mcp#readme",
  "keywords": [
    "signwell",
    "mcp",
    "model-context-protocol",
    "esignature",
    "cli"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "signwell-mcp": "build/index.js"
  },
  "scripts": {
    "start": "node build/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src test",
    "format": "biome format --write src test",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=build/index.js --packages=external --banner:js=\"#!/usr/bin/env node\" --define:__PKG_VERSION__='\"'$(node -p \"require('./package.json').version\")'\"' && chmod +x build/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "unpdf": "^1.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.9",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3"
  }
}
